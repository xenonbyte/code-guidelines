root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

# .NET code style (machine-enforced when EnforceCodeStyleInBuild=true, see Directory.Build.props)
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_readonly_field = true:warning
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_prefer_auto_properties = true:warning

# C# code style
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_prefer_braces = true:warning
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_pattern_matching = true:warning
csharp_style_prefer_null_check_over_type_check = true:warning

# Naming: interfaces must start with I
dotnet_naming_rule.interface_should_be_prefixed_with_i.severity = warning
dotnet_naming_rule.interface_should_be_prefixed_with_i.symbols = interface_symbol
dotnet_naming_rule.interface_should_be_prefixed_with_i.style = prefix_i_style
dotnet_naming_symbols.interface_symbol.applicable_kinds = interface
dotnet_naming_style.prefix_i_style.required_prefix = I
dotnet_naming_style.prefix_i_style.capitalization = pascal_case

# Selected analyzer diagnostics escalated to warning (paired with TreatWarningsAsErrors)
dotnet_diagnostic.CA1062.severity = warning
dotnet_diagnostic.CA2007.severity = warning
dotnet_diagnostic.CA1051.severity = warning
